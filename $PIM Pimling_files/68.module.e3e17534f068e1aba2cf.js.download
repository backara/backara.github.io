dung được nhúng cho phép bạn thoải mái lựa chọn nội dung để hiển thị cho đối tượng người xem của mình.","ttembeds_main_header":"Nội dung được nhúng từ TikTok","ttembeds_meta_desc":"Bạn có thể chọn lọc video, hồ sơ, hashtag hoặc âm thanh bất kỳ từ các video phổ biến hoặc tạo danh sách phát của riêng bạn để người khác khám phá.","ttembeds_meta_title":"Nội dung được nhúng từ TikTok | Hiển thị nội dung từ TikTok trên trang web của bạn.","ttep_add_video":"Vui lòng thêm một video","ttep_back_icon":"Biểu tượng quay lại","ttep_back_to_qr":"Quay lại Mã QR","ttep_close_modal":"Mô thái đóng","ttep_close_modal_icon":"Biểu tượng Mô thái đóng","ttep_copy_link":"Sao chép Liên kết","ttep_desktop_tool_login_confirm_desc":"Quay lại Effect House để tiếp tục","ttep_desktop_tool_login_confirm_title":"Bạn đã đăng nhập!","ttep_desktop_tool_login_redirect_btn":"Tiếp tục","ttep_desktop_tool_login_redirect_desc":"Tiếp tục đến Effect House?","ttep_desktop_tool_login_redirect_title":"Bạn đã đăng nhập với tên là {username}","ttep_desktop_tool_same_login_btn":"Chuyển đổi tài khoản","ttep_desktop_tool_same_login_desc":"Chuyển sang tài khoản của bạn mà hiện đang đăng nhập Effect House","ttep_desktop_tool_same_login_title":"Bạn đã đăng nhập với tên là {username}","ttep_downloadOld_banner_link":"Tải xuống phiên bản mới nhất","ttep_downloadOld_body_desc":"Lưu ý: Một số phiên bản có lỗi và vấn đề về khả năng tương thích đã xác định","ttep_downloadOld_body_title":"Tải xuống phiên bản cũ của Effect House","ttep_downloadOld_tableTitle_date":"Ngày phát hành","ttep_downloadOld_tableTitle_links":"Liên kết tải xuống","ttep_downloadOld_tableTitle_notes":"Ghi chú phát hành","ttep_downloadOld_tableTitle_version":"Phiên bản","ttep_download_banner_btn_mac":"Tải về cho {macos} hoặc {macosM1}","ttep_download_banner_btn_single":"Tải về cho {os1}","ttep_download_banner_macapple":"Mac (chip Apple)","ttep_download_banner_macos":"Mac (Intel)","ttep_download_banner_not_available":"Effect House hiện chỉ có sẵn trên máy tính để bàn hoặc máy tính xách tay chạy hệ điều hành Mac hoặc Windows. Vui lòng truy cập trang này từ thiết bị được hỗ trợ để bắt đầu.","ttep_download_banner_title":"Effect House cho Mac & Windows","ttep_download_banner_windows":"Windows","ttep_download_followUs":"Theo dõi chúng tôi","ttep_download_mobile_signup":"Đăng ký để nhận email có chứa liên kết tải về cho máy tính chạy hệ điều hành Mac hoặc Windows","ttep_download_mobile_signupbonuses":"Ngoài ra, bạn còn nhận được lời khuyên dành cho nhà sáng tạo, thông tin cập nhật về công cụ, v.v.","ttep_download_page_continue_btn":"Tiếp tục","ttep_download_page_cookiesLink":"Chính sách Cookie","ttep_download_page_discordLink":"Tham gia cùng chúng tôi trên Discord","ttep_download_page_download_pc_btn":"Tải về cho Windows","ttep_download_page_effectGuideLink":"Hướng dẫn về hiệu ứng","ttep_download_page_mobile_availability":"Effect House hiện chỉ có sẵn cho máy tính Mac. Vui lòng truy cập trang web trên máy Mac để bắt đầu.","ttep_download_page_privacy_checkbox":"Chính sách quyền riêng tư của TikTok","ttep_download_page_quickstartLink":"Hướng dẫn bắt đầu nhanh","ttep_download_page_releaseNotesLink":"Ghi chú phát hành","ttep_download_page_tnc_agreement_checkbox":"Tôi đồng ý với tất cả điều khoản và điều kiện bên dưới","ttep_download_page_tnc_title":"Điều khoản và điều kiện TikTok Effect House","ttep_download_page_tosLink":"Điều khoản dịch vụ","ttep_download_page_tos_checkbox":"Điều khoản dịch vụ TikTok Effect House","ttep_download_page_tos_content":"Bằng việc tiếp tục, bạn đồng ý với {termsOfService} của chúng tôi. Để biết thêm thông tin về cách chúng tôi thu thập, sử dụng và chia sẻ dữ liệu của bạn, vui lòng xem {privacyPolicy}. Để biết thêm thông tin về cookie và các công nghệ tương tự mà chúng tôi sử dụng, vui lòng xem {cookiesPolicy}.","ttep_download_page_tos_privacyLink":"Chính sách quyền riêng tư","ttep_download_requirements_cpu":"CPU","ttep_download_requirements_gpu":"GPU","ttep_download_requirements_mac_cpu":"Intel Core i3 2.5Ghz / AMD FX 4300 2.6Ghz / Apple M1","ttep_download_requirements_mac_gpu1":"Intel HD Graphics 4000 / Nvidia GeForce 710 / AMD Radeon HD 6450","ttep_download_requirements_mac_gpu2":"Đã cài đặt trình điều khiển thẻ đồ họa mới nhất","ttep_download_requirements_mac_os":"MacOS 10.15 trở lên","ttep_download_requirements_mac_title":"Yêu cầu hệ thống tối thiểu cho máy Mac","ttep_download_requirements_macwin_monitor":"1280x768","ttep_download_requirements_macwin_ram":"4 GB","ttep_download_requirements_monitor":"Độ phân giải màn hình","ttep_download_requirements_os":"Hệ điều hành","ttep_download_requirements_ram":"RAM","ttep_download_requirements_win_cpu1":"kiến trúc x64 với hỗ trợ SSE2","ttep_download_requirements_win_cpu2":"Intel Core i3 2.5GHz / AMD Ryzen 1000","ttep_download_requirements_win_faq":"FAQ","ttep_download_requirements_win_gpu1":"Hỗ trợ DX11","ttep_download_requirements_win_gpu2":"Intel HD Graphics 4000 / Nvidia GeForce 710 / AMD Radeon HD 6450","ttep_download_requirements_win_os":"Windows 10 (64-bit)","ttep_download_requirements_win_title":"Yêu cầu hệ thống tối thiểu cho máy Windows","ttep_download_resources_title":"Tài nguyên","ttep_effect_details_page_add_comments_desc":"Bạn còn muốn chúng tôi biết điều gì về hiệu ứng của bạn không?","ttep_effect_details_page_add_comments_title":"Bình luận bổ sung","ttep_effect_details_page_category_accessories":"Phụ kiện","ttep_effect_details_page_category_animals":"Thú Cưng","ttep_effect_details_page_category_atmosphere":"Môi trường","ttep_effect_details_page_category_beauty":"Làm đẹp","ttep_effect_details_page_category_desc":"Chọn một danh mục cho hiệu ứng của bạn","ttep_effect_details_page_category_editing":"Chỉnh sửa","ttep_effect_details_page_category_events":"Sự kiện","ttep_effect_details_page_category_funny":"Vui nhộn","ttep_effect_details_page_category_green_screen":"Phông xanh","ttep_effect_details_page_category_interactive":"Tương tác","ttep_effect_details_page_category_music":"Âm nhạc","ttep_effect_details_page_category_worldar":"Thế giới Thực tế ảo tăng cường","ttep_effect_details_page_challenge_desc":"Chọn một Thử thách cho hiệu ứng của bạn","ttep_effect_details_page_challenge_disclaimer":"Khi tham gia vào Thử thách này, tôi đồng ý với {termsAndConditionsLink}","ttep_effect_details_page_challenge_terms":"Điều khoản và điều kiện của thử thách","ttep_effect_details_page_challenge_title":"Thử thách","ttep_effect_details_page_demo_requirements_desc":"<ul>\\n<li>Tỷ lệ khung hình: Dọc (9:16)_x000B_</li>\\n<li>Định dạng tệp: MOV hoặc MP4_x000B_</li>\\n<li>Dung lượng tệp tối đa: 32 MB</li>\\n<li>Độ dài video tối đa: 15 giây</li>\\n</ul>","ttep_effect_details_page_demo_requirements_desc_aspect_ratio":"Tỷ lệ khung hình: Chân dung (9:16)","ttep_effect_details_page_demo_requirements_desc_file_format":"Định dạng tệp: MOV hoặc MP4","ttep_effect_details_page_demo_requirements_desc_max_file_size":"Kích thước tệp tối đa: 32 MB","ttep_effect_details_page_demo_requirements_desc_max_video_length":"Thời lượng video tối đa: 15 giây","ttep_effect_details_page_demo_requirements_title":"Yêu cầu đối với video demo","ttep_effect_details_page_demo_text":"TikTok sẽ xét duyệt các video demo và những video này sẽ không hiển thị công khai","ttep_effect_details_page_desc":"Cho chúng tôi biết về hiệu ứng của bạn để hỗ trợ người dùng TikTok tìm thấy hiệu ứng.","ttep_effect_details_page_order_id":"ID Yêu cầu","ttep_effect_details_page_orderid_desc":"Vui lòng đảm bảo rằng bạn nhập đúng ID đơn hàng cho hiệu ứng của bạn. Nếu bạn không biết ID hàng của mình, hãy liên hệ với <a href=\\"https://www.tiktok.com/business/en-US/contact\\">TikTok for Business</a>","ttep_effect_details_page_submit_btn":"Gửi","ttep_effect_details_page_tags_desc":"Thêm tối đa 5 thẻ để mô tả hiệu ứng của bạn","ttep_effect_details_page_tags_help_text":"Nhấn Enter sau mỗi thẻ","ttep_effect_details_page_tags_title":"Thẻ (tối đa 5)","ttep_effect_details_page_title":"Chi tiết hiệu ứng","ttep_effect_details_page_upload_btn":"Tải lên","ttep_effect_details_page_upload_video":"Tải video demo lên","ttep_effect_details_page_upload_videoOptional":"Tải video demo lên (không bắt buộc)","ttep_effect_details_page_view_guidelines":"Xem Hướng dẫn cách gửi","ttep_effect_details_submit_manage_effects_btn":"Quản lý hiệu ứng","ttep_effect_details_submit_tooltip":"Bạn có thể thay đổi tên và biểu tượng hiệu ứng của mình trong công cụ TikTok Effect House cho máy tính để bàn.","ttep_effect_submit_confirm_desc":"Chúng tôi sẽ thông báo cho bạn sau khi xem xét xong hiệu ứng của bạn. Quy trình xem xét thường mất từ 1-3 ngày làm việc.","ttep_effect_submit_confirm_header":"Đã gửi hiệu ứng của bạn","ttep_error_description":"Quay lại hoặc làm mới trang để thử lại","ttep_error_description404":"Hệ thống không thể tìm thấy trang bạn đang tìm kiếm. Trang này có thể đã bị xóa, đổi tên hoặc không tồn tại ngay từ đầu.","ttep_error_occur":"Đã xảy ra lỗi.","ttep_error_search":"Tìm kiếm:","ttep_error_title":"Rất tiếc, đã xảy ra lỗi","ttep_error_title404":"Rất tiếc! 404","ttep_fill_orderid":"Vui lòng điền ID đơn hàng","ttep_generic_error":"Đã xảy ra lỗi. Vui lòng thử lại sau.","ttep_homepage_amplify_cta":"Bắt đầu tạo","ttep_homepage_amplify_desc":"Xác định các xu hướng định hình văn hóa của chúng ta và chia sẻ hiệu ứng Thực tế tăng cường của bạn với hàng trăm triệu người dùng trên khắp thế giới.","ttep_homepage_amplify_title":"Tăng cường phạm vi tiếp cận của bạn","ttep_homepage_buildwithus_btn":"Tham gia cộng đồng","ttep_homepage_buildwithus_desc":"Chúng tôi đang xây dựng các công cụ sáng tạo Thực tế tăng cường (AR) thế hệ mới dựa trên ý kiến đóng góp và ý tưởng của bạn. Tương lai của các hiệu ứng sáng tạo bắt đầu ngay từ đây và bắt đầu ngay trên TikTok.","ttep_homepage_buildwithus_title":"Hãy xây dựng cùng chúng tôi","ttep_homepage_desc":"Tạo các hiệu ứng Thực tế tăng cường sống động cho TikTok","ttep_homepage_download_btn":"Tải về Effect House","ttep_homepage_download_btn_now":"Tải về ngay","ttep_homepage_getinspired_desc":"Kết nối và cộng tác với cộng đồng toàn cầu ngày càng phát triển gồm những nhà sáng tạo hiệu ứng và nhà cải cách.","ttep_homepage_getinspired_title":"Tràn đầy cảm hứng","ttep_homepage_learn_title":"Học","ttep_homepage_menu_log_out":"Đăng xuất","ttep_homepage_menu_log_out_single":"Đăng xuất","ttep_homepage_nav_header_download":"Tải về","ttep_homepage_nav_header_latest":"Mới nhất","ttep_homepage_nav_header_manage":"Quản lý","ttep_homepage_sharpen_btn":"Xem tài nguyên học tập","ttep_homepage_sharpen_desc":"Bất kể bạn là nhà sáng tạo nội dung Thực tế tăng cường chuyên nghiệp hay chỉ vừa mới bắt đầu, hãy sử dụng hướng dẫn từng bước, các mẫu và hướng dẫn video của chúng tôi để học cách sáng tạo các trải nghiệm thực tế tăng cường cho TikTok.","ttep_homepage_sharpen_title":"Mài giũa các kỹ năng phát triển nội dung Thực tế tăng cường của bạn","ttep_homepage_showcase_desc":"Effect House giúp bạn hiện thực hóa những câu chuyện của mình thông qua các tính năng mạnh mẽ, trực quan và giàu khả năng biểu đạt. Các khả năng tích hợp của chúng tôi — từ theo dõi nâng cao cho đến tương tác phong phú — cho phép bạn thử nghiệm, sáng tạo, xem trước, đăng tải và quản lý tất cả các hiệu ứng của mình trên TikTok.","ttep_homepage_showcase_title":"Thể hiện khả năng sáng tạo của bạn","ttep_homepage_title":"Sự sáng tạo chính là đây","ttep_homepage_what_is_eh_button":"Tìm hiểu thêm","ttep_homepage_what_is_eh_description":"Effect House là công cụ Thực tế tăng cường mạnh mẽ, giúp bạn dễ dàng sáng tạo, đăng và chia sẻ các hiệu ứng tăng cường chất lượng cao cho TikTok. Là công cụ được xây dựng cho những nhà thiết kế và nhà sáng tạo mới bắt đầu và cả những người đã có trình độ nâng cao, Effect House hỗ trợ những nhà sáng tạo đem đến trải nghiệm tương tác cho người dùng TikTok trên khắp thế giới.","ttep_homepage_what_is_eh_title":"Khám phá Effect House","ttep_kids_mode_subtitle":"Những người dùng dưới 13 tuổi không thể sử dụng TikTok Effect House. Chúng tôi xin lỗi vì khiến bạn cảm thấy bất tiện.","ttep_kids_mode_t